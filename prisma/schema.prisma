// PhDapp data model

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────── Auth (NextAuth + Google) ─────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("student") // "admin" | "supervisor" | "student"
  color         String    @default("#6366f1") // accent color in UI
  kanbanLastSeenAt DateTime?
  kanbanDismissedTicketIds String?  // JSON array of ticket ids dismissed since last /kanban visit
  calendarLastSeenAt DateTime?
  calendarDismissedEventIds String?  // JSON array of event ids dismissed since last /calendar visit
  emailDigest    Boolean   @default(true) // weekly summary email opt-out
  readingLastSeenAt DateTime?
  notificationsLastSeenAt DateTime?
  teamSuggestionsLastSeenAt DateTime?
  feedbackLastSeenAt DateTime?

  // Admin-only visibility: when did this user actually use the app?
  //   lastLoginAt  — bumped in the NextAuth signIn event
  //   lastActiveAt — bumped on each authenticated page render, throttled
  //                  (~5 min granularity) so we don't hammer the DB
  lastLoginAt    DateTime?
  lastActiveAt   DateTime?

  // External profile links (LinkedIn / ORCID / Google Scholar) — shown on
  // user profile cards and team views. Students keep their own copies on
  // the Student model (so they edit those via the student form).
  linkedinUrl    String?
  orcidId        String?
  scholarUrl     String?

  // Informational alternate emails (JSON array of strings). Displayed on
  // the user's profile alongside LinkedIn / ORCID / Scholar. Notifications
  // still go to the primary `email` only; alternates are not used for
  // login or for digest fan-out (yet).
  alternateEmails String?

  accounts Account[]
  sessions Session[]

  // Domain relations
  studentProfile        Student?         @relation("StudentUser")
  supervisedStudents    Student[]        @relation("SupervisorOfStudent")
  coSupervisedStudents  CoSupervisor[]
  assignedTickets       Ticket[]         @relation("TicketAssignee")
  createdTickets        Ticket[]         @relation("TicketCreator")
  comments              Comment[]
  messages              Message[]
  channelMemberships    ChannelMember[]
  events                Event[]          @relation("EventOwner")
  eventAttendances      EventAttendee[]
  activityLogs          ActivityLog[]    @relation("ActivityActor")
  favoritesStarred      FavoriteFile[]   @relation("FavoriteStarredBy")
  supervisorNotes       SupervisorNote[] @relation("SupervisorNoteAuthor")
  readingItemsAdded     ReadingItem[]    @relation("ReadingItemAddedBy")
  readingDecisions      ReadingItem[]    @relation("ReadingItemDecisionBy")
  availability          Availability[]
  teamNotes             TeamNote[]       @relation("TeamNoteAuthor")
  advisorSuggestions    AdvisorSuggestion[] @relation("AdvisorSuggestionAuthor")
  taskGroupsCreated     TaskGroup[]      @relation("TaskGroupCreatedBy")
  notifications         Notification[]
  feedbackSubmitted     Feedback[]       @relation("FeedbackAuthor")
  feedbackHandled       Feedback[]       @relation("FeedbackRepliedBy")
  feedbackMessages      FeedbackMessage[] @relation("FeedbackMessageAuthor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ───────── Domain ─────────

model Student {
  id              String    @id @default(cuid())
  userId          String?   @unique
  user            User?     @relation("StudentUser", fields: [userId], references: [id])
  fullName        String
  alias           String?
  email           String    @unique
  avatarUrl       String?
  color           String    @default("#06b6d4")
  programYear     Int       @default(1)
  startDate       DateTime  @default(now())
  expectedEndDate DateTime?
  thesisTitle     String?
  researchArea    String?
  status          String    @default("active") // active | on_leave | submitted | graduated | withdrawn

  // Google-linked resources
  driveFolderId   String?
  calendarId      String?
  chatSpaceId     String?

  // External profile links
  linkedinUrl     String?
  orcidId         String?
  websiteUrl      String?
  scholarUrl      String?
  // Informational alternate emails (JSON array of strings) — mirrors
  // User.alternateEmails. Displayed on the student profile header
  // alongside the primary email; not used for login or notifications.
  alternateEmails String?

  supervisorId    String
  supervisor      User      @relation("SupervisorOfStudent", fields: [supervisorId], references: [id])

  coSupervisors   CoSupervisor[]
  tickets         Ticket[]
  events          Event[]
  channels        Channel[]
  activityLogs    ActivityLog[]
  favorites       FavoriteFile[]
  thesisChapters  ThesisChapter[]
  publications    Publication[]
  supervisorNotes SupervisorNote[]
  readingItems    ReadingItem[]
  checkIns        CheckIn[]
  taskGroups      TaskGroup[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model ThesisChapter {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  title     String
  status    String   @default("planned") // planned | drafting | in_review | revising | done
  order     Int      @default(0)
  driveUrl  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Publication {
  id          String    @id @default(cuid())
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  title       String
  venue       String?
  type        String    @default("journal") // journal | conference | preprint | other
  status      String    @default("in_prep") // in_prep | submitted | under_review | major_rev | minor_rev | accepted | published | rejected
  authors     String?
  url         String?
  driveUrl    String?
  submittedAt DateTime?
  decisionAt  DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SupervisorNote {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("SupervisorNoteAuthor", fields: [authorId], references: [id])
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ReadingItem {
  id               String   @id @default(cuid())
  studentId        String
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  title            String
  authors          String?
  url              String?
  addedById        String
  addedBy          User     @relation("ReadingItemAddedBy", fields: [addedById], references: [id])
  proposedByStudent Boolean @default(false)
  proposalNote     String?  // proposer's reason / why it's relevant
  status           String   @default("approved") // proposed | approved | reading | done | rejected
  decisionById     String?
  decisionBy       User?    @relation("ReadingItemDecisionBy", fields: [decisionById], references: [id])
  decisionNote     String?  // supervisor's note on approve / reject
  // Threaded discussion (student ↔ supervisors) — same Comment table
  // used for Tasks and Calendar events. See model Comment.
  comments         Comment[] @relation("ReadingComments")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // task.assigned | task.comment | reading.proposed | reading.decided | meeting.tasks
  message   String
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
}

model TeamNote {
  id        String   @id @default(cuid())
  authorId  String
  author    User     @relation("TeamNoteAuthor", fields: [authorId], references: [id])
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A Team Advisor's suggestion to the supervisors. Can be tagged with one
// or more students, or none at all (general / team-wide).
model AdvisorSuggestion {
  id         String   @id @default(cuid())
  authorId   String
  author     User     @relation("AdvisorSuggestionAuthor", fields: [authorId], references: [id])
  body       String
  studentIds String[] @default([]) // empty = general / not student-specific
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([createdAt])
}

// Suggestion mailbox: any user can send the admins a bug report,
// improvement idea, or other feedback. Admins triage (status) and reply.
// Replies are now a back-and-forth thread (FeedbackMessage). The legacy
// adminReply/repliedBy/repliedAt fields are kept for old entries — new
// replies go in the messages table so both author and admin can post.
model Feedback {
  id          String    @id @default(cuid())
  authorId    String
  author      User      @relation("FeedbackAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  kind        String    @default("idea") // "bug" | "idea" | "other"
  subject     String
  body        String
  status      String    @default("open") // "open" | "planned" | "in_progress" | "done" | "declined"
  imageUrl    String?   // optional screenshot/photo to illustrate the report
  adminReply  String?   // LEGACY — first admin reply; new replies use FeedbackMessage
  repliedById String?
  repliedBy   User?     @relation("FeedbackRepliedBy", fields: [repliedById], references: [id])
  repliedAt   DateTime?
  messages    FeedbackMessage[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([authorId])
  @@index([status])
  @@index([createdAt])
}

// One message in a Feedback thread. Authors and admins can both post.
model FeedbackMessage {
  id         String   @id @default(cuid())
  feedbackId String
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation("FeedbackMessageAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  body       String
  editedAt   DateTime?
  createdAt  DateTime @default(now())

  @@index([feedbackId, createdAt])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Availability {
  id        String   @id @default(cuid())
  userId    String // the supervisor who is away/busy
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  startsAt  DateTime
  endsAt    DateTime
  label     String? // supervisor's own reference (e.g. "Conference") — NEVER shown to students
  kind      String   @default("away") // away | busy
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CheckIn {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  weekOf    DateTime // Monday 00:00 UTC of the ISO week
  did       String?
  blockers  String?
  next      String?
  wellbeing Int?     // 1..5 — supervisor-level visibility only
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, weekOf])
}

model CoSupervisor {
  id        String  @id @default(cuid())
  studentId String
  userId    String
  role      String  @default("co_supervisor") // co_supervisor | external_advisor | committee
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([studentId, userId])
}

model Ticket {
  id           String    @id @default(cuid())
  title        String
  description  String?
  status       String    @default("backlog") // backlog | todo | in_progress | review | blocked | done
  priority     String    @default("medium")  // low | medium | high | urgent
  category     String    @default("research") // research | writing | admin | reading | meeting | experiment | publication | conference | other
  dueDate      DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  // Student requested completion ("Mark as completed"); a supervisor then
  // moves it to Done. Cleared when status becomes done or it's un-requested.
  completionRequestedAt DateTime?
  archivedAt   DateTime? // soft-delete: set on delete, cleared on undo (§14)
  estimateHours Float?
  actualHours   Float?

  // Linked resources
  driveFolderUrl String?
  channelId      String?

  // JSON array of { id, text, done } — kept inline rather than in a child table
  // because subtasks are always loaded/written with their parent task.
  subtasks       String?

  // JSON array of { id, label, url } — external links (papers, websites,
  // repos, Overleaf docs…). Separate from `driveFolderUrl` which is a
  // single dedicated field with its own Drive-picker affordance.
  links          String?

  // Optional student assignment. Three-state visibility:
  //   studentId set                    → student-specific (that student + team)
  //   studentId null, isGeneral false  → team-only (non-students only)
  //   studentId null, isGeneral true   → general (visible to everyone)
  // Students cannot create studentId=null OR isGeneral=true (enforced in
  // /api/tickets).
  studentId    String?
  student      Student?  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  isGeneral    Boolean   @default(false)

  // Optional parent group → 3-level hierarchy: Group > Task > Subtask.
  groupId      String?
  group        TaskGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  assigneeId   String?
  assignee     User?     @relation("TicketAssignee", fields: [assigneeId], references: [id])

  createdById  String
  createdBy    User      @relation("TicketCreator", fields: [createdById], references: [id])

  channel      Channel?  @relation(fields: [channelId], references: [id])
  comments     Comment[]
  tags         TicketTag[]
  dueEvent     Event?    @relation("TaskDueEvent")
  subtaskDueEvents Event[] @relation("SubtaskDueEvents")
  linkedEvents Event[]   @relation("RelatedTaskEvents")
  // Dependencies: this task waits on `dependsOn`; `dependents` wait on it.
  dependsOn    TaskDependency[] @relation("Dependent")
  dependents   TaskDependency[] @relation("DependsOn")
  order        Int       @default(0)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// Task dependency edge: `dependent` is blocked until `dependsOn` is done.
model TaskDependency {
  id          String @id @default(cuid())
  dependentId String
  dependsOnId String
  dependent   Ticket @relation("Dependent", fields: [dependentId], references: [id], onDelete: Cascade)
  dependsOn   Ticket @relation("DependsOn", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([dependentId, dependsOnId])
  @@index([dependsOnId])
}

// Top of the 3-level hierarchy: a named group of tasks for one student.
model TaskGroup {
  id          String   @id @default(cuid())
  name        String
  color       String   @default("#6366f1")
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User     @relation("TaskGroupCreatedBy", fields: [createdById], references: [id])
  tickets     Ticket[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TicketTag {
  id       String  @id @default(cuid())
  ticketId String
  label    String
  color    String  @default("#94a3b8")
  ticket   Ticket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

// Polymorphic: a Comment attaches to EITHER a Ticket (task) OR an Event.
// Exactly one of ticketId/eventId must be set — DB CHECK enforces this.
// Comments can also be threaded via parentId (1-level reply UX); the parent
// lives in the same Ticket/Event as the reply (server enforces).
model Comment {
  id            String       @id @default(cuid())
  body          String
  ticketId      String?
  eventId       String?
  readingItemId String?
  parentId      String?
  authorId      String
  ticket        Ticket?      @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  event         Event?       @relation("EventComments", fields: [eventId], references: [id], onDelete: Cascade)
  readingItem   ReadingItem? @relation("ReadingComments", fields: [readingItemId], references: [id], onDelete: Cascade)
  parent        Comment?     @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       Comment[]    @relation("CommentReplies")
  author        User         @relation(fields: [authorId], references: [id])
  createdAt     DateTime     @default(now())
  editedAt      DateTime? // set when the author edits; drives the "edited" mark

  @@index([ticketId])
  @@index([eventId])
  @@index([readingItemId])
  @@index([parentId])
}

// ───────── Calendar (mirrors Google Calendar) ─────────

model Event {
  id              String   @id @default(cuid())
  title           String
  description     String?
  location        String?
  startsAt        DateTime
  endsAt          DateTime
  allDay          Boolean  @default(false)
  meetingUrl      String?
  // iCal RRULE body (without the "RRULE:" prefix), e.g.
  // "FREQ=WEEKLY;INTERVAL=1;UNTIL=20261231T235959Z". Null = one-off.
  // Editing/deleting a recurring event affects the whole series (MVP).
  recurrenceRule  String?
  isMeeting       Boolean  @default(false)
  agenda          String?  // JSON array of { id, text, addedById }
  meetingNotes    String?
  googleEventId   String?  @unique
  googleCalendarId String?

  ownerId   String
  owner     User     @relation("EventOwner", fields: [ownerId], references: [id])

  studentId String?
  student   Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  // Three-state visibility (mirrors Ticket.isGeneral):
  //   studentId set                    → student-specific
  //   studentId null, isGeneral false  → team-only (non-students only)
  //   studentId null, isGeneral true   → general (visible to everyone)
  isGeneral Boolean  @default(false)

  // If this event mirrors a task's due date, point back to it. Null for
  // regular events. We render task-events differently in the calendar.
  ticketId  String?  @unique
  ticket    Ticket?  @relation("TaskDueEvent", fields: [ticketId], references: [id], onDelete: Cascade)

  // Optional MANUAL link to a Task this event relates to (e.g. a meeting
  // to discuss a task's progress, scheduled before its due date). Distinct
  // from `ticketId`, which is the automatic mirror of a task's DUE date.
  // SetNull so deleting/archiving the task leaves the event intact.
  linkedTaskId String?
  linkedTask   Ticket? @relation("RelatedTaskEvents", fields: [linkedTaskId], references: [id], onDelete: SetNull)

  // If this event mirrors a SUB-task's deadline: the parent task + which
  // subtask (its id within the task's subtasks JSON). One event per
  // (parent task, subtask). Cascades when the parent task is hard-deleted.
  subtaskParentId String?
  subtaskParent   Ticket? @relation("SubtaskDueEvents", fields: [subtaskParentId], references: [id], onDelete: Cascade)
  subtaskKey      String?

  // JSON array of { id, label, url } — external links (mirrors Ticket.links).
  // Separate from `meetingUrl` (the single dedicated Join button) and from
  // `agenda` (per-meeting talking points).
  links     String?

  // Optional single Drive folder attached to this event (mirrors
  // Ticket.driveFolderUrl). When the event has a student, the picker is
  // scoped to that student's Drive folder.
  driveFolderUrl String?

  attendees EventAttendee[]
  comments  Comment[]  @relation("EventComments")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([subtaskParentId, subtaskKey])
  @@index([linkedTaskId])
}

model EventAttendee {
  id       String  @id @default(cuid())
  eventId  String
  userId   String
  status   String  @default("invited") // invited | accepted | declined | tentative
  event    Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

// ───────── In-app Chat ─────────

model Channel {
  id          String  @id @default(cuid())
  name        String
  description String?
  kind        String  @default("student")  // student | cosupervisors | direct | general
  color       String  @default("#8b5cf6")

  studentId   String?
  student     Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  members     ChannelMember[]
  messages    Message[]
  tickets     Ticket[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChannelMember {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  lastRead  DateTime @default(now())
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
}

model Message {
  id          String   @id @default(cuid())
  channelId   String
  authorId    String
  body        String
  attachments String?  // JSON: [{name, url}]
  channel     Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author      User     @relation(fields: [authorId], references: [id])
  // Optional "in reply to" another message in the same channel.
  replyToId   String?
  replyTo     Message?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies     Message[] @relation("MessageReplies")
  createdAt   DateTime @default(now())
  // Set when the author edits the body after sending. UI shows a small
  // "(edited)" suffix whenever this is non-null. Stays null on the
  // initial send so the indicator only appears after a real edit.
  editedAt    DateTime?

  @@index([replyToId])
}

// ───────── Log book ─────────

model FavoriteFile {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  driveFileId String
  name        String
  mimeType    String
  webViewLink String?
  iconLink    String?
  parentFolderId String?
  starredById String
  starredBy   User     @relation("FavoriteStarredBy", fields: [starredById], references: [id])
  createdAt   DateTime @default(now())

  @@unique([studentId, driveFileId])
  @@index([studentId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  actorId   String
  actor     User     @relation("ActivityActor", fields: [actorId], references: [id])
  actorRoleAtTime String  // snapshot: "student" | "co_supervisor" | "supervisor"

  studentId String?
  student   Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  action    String   // e.g. "ticket.create", "ticket.update", "ticket.delete", "event.create", "event.update", "event.delete"
  entityType String? // "ticket" | "event" | "student" | "channel"
  entityId   String?

  summary   String   // human-readable, e.g. "created ticket 'Draft intro chapter'"
  details   String?  // optional JSON payload of changed fields

  readBy    String?  // JSON array of user ids who marked it read
  createdAt DateTime @default(now())

  @@index([studentId, createdAt])
  @@index([actorId, createdAt])
}
